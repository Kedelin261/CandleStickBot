# =============================================================================
# CandleStickBot .gitignore
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Environment variables (NEVER commit these)
.env
.env.local
.env.*.local

# Local config overrides (contain broker credentials)
config/local_config.yaml
config/*.local.yaml

# Database files (dev data)
data/
*.db
*.sqlite
*.sqlite3

# Log files
logs/
*.log
*.jsonl

# MT5 files
*.ex5
*.ex4

# Reports (generated)
reports/
*.html

# Alembic versions (committed separately)
# migrations/versions/

# Testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml
pytest_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Jupyter
.ipynb_checkpoints

# Distribution
*.tar.gz
*.zip
*.whl

# Wrangler (if any Cloudflare tools are used for dashboard)
.wrangler/

# Hypothesis
.hypothesis/
