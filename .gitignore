# =============================================================================
# CandleStickBot — .gitignore
# =============================================================================

# -----------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.pyc
*.pyo
*.pyd

# -----------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# -----------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
htmlcov/
.tox/
.nox/
nosetests.xml

# -----------------------------------------------------------------------
# Sensitive Configuration
# -----------------------------------------------------------------------
# NEVER commit local config (may contain credentials/tokens)
config/local_config.yaml
config/*.local.yaml

# MT5 credentials should only be in local_config.yaml (gitignored)
# default_config.yaml contains placeholder credentials ONLY

# -----------------------------------------------------------------------
# Database Files
# -----------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# Wrangler local dev state (if ever used)
.wrangler/

# -----------------------------------------------------------------------
# Logs & Reports
# -----------------------------------------------------------------------
logs/
*.log
*.log.*
*.jsonl
reports/*.json
reports/*.csv
reports/*.html
reports/*.xlsx

# -----------------------------------------------------------------------
# IDE & Editors
# -----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------
# Data Files (can be large, regenerate from MT5)
# -----------------------------------------------------------------------
# Only ignore a top-level /data/ directory (raw market data dumps).
# Do NOT ignore src/data/ (source package) or tests/unit/data/ (tests).
/data/
*.csv.gz
*.feather
*.parquet

# -----------------------------------------------------------------------
# Alembic
# -----------------------------------------------------------------------
# Keep migrations but ignore the compiled .pyc in migrations
migrations/__pycache__/

# -----------------------------------------------------------------------
# PM2 (if ever used for process management)
# -----------------------------------------------------------------------
.pm2/
ecosystem.config.js

# -----------------------------------------------------------------------
# Jupyter Notebooks (exploration only, not part of codebase)
# -----------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------
# Environment Files
# -----------------------------------------------------------------------
.env
.env.local
.env.development
.env.test
.env.production
*.env

# -----------------------------------------------------------------------
# Build Artifacts
# -----------------------------------------------------------------------
*.tar.gz
*.zip
*.whl
